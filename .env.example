# =============================================================================
# Copy to .env and adjust values:  cp .env.example .env
# =============================================================================

# --- PostgreSQL (docker-compose service: db) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=app_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg://app:change_me_secure_password@db:5432/app_db

SECRET_KEY=change_me_to_a_long_random_string
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://frontend:5173

# --- Recoil AI / LLM ---
# Provider: gemini | openai
AI_PROVIDER=gemini
# true = every section uses demo data (no API calls)
AI_MOCK_MODE=false
# Sections that call Gemini when AI_MOCK_MODE=false and GEMINI_API_KEY is set:
# red_team, meme, risk, crisis, brand (comma-separated; brand omitted = demo)
AI_GEMINI_FEATURES=red_team,meme,risk,crisis

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Frontend (Vite) ---
# Leave empty for `npm run dev` (proxies /api to backend). Set for Docker/production:
VITE_API_URL=http://localhost:8000
